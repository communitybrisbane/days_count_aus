rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function changed() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ═══════════════════════════════════════════
    // Users
    // ═══════════════════════════════════════════
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Own update: whitelist safe fields only
      // isPro, createdAt, uid are immutable
      allow update: if isOwner(userId)
                     && changed().hasOnly([
                       'displayName', 'displayNameLower', 'photoURL', 'region', 'showRegion', 'goal', 'mainMode',
                       'departureDate', 'returnStartDate', 'status', 'weeklyGoal',
                       'groupIds',
                       'currentStreak', 'lastPostAt', 'totalXP',
                       'dailyLikeCount', 'lastLikeDate', 'streakWarningSent',
                       'weekStreak', 'lastCompletedWeekStart'
                     ]);

      // Other user update: XP grant from like system only (+5 fixed)
      allow update: if isAuth()
                     && request.auth.uid != userId
                     && changed().hasOnly(['totalXP'])
                     && request.resource.data.totalXP == resource.data.totalXP + 5;

      // Private subcollection: blockedUsers, fcmToken — owner only
      match /private/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId)
                       && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['blockedUsers', 'fcmToken', 'notificationPrefs', 'reportedPosts', 'kickedFrom']);
      // Note: kickedFrom is also written by Cloud Function (admin SDK, bypasses rules)
      }

      // Following subcollection — owner only (follower list intentionally hidden per SPEC)
      match /following/{targetId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // BlockedBy subcollection — written by Cloud Function, readable by owner only
      match /blockedBy/{blockerUid} {
        allow read: if isOwner(userId);
        allow write: if false; // CF uses Admin SDK (bypasses rules)
      }
    }

    // ═══════════════════════════════════════════
    // Posts
    // ═══════════════════════════════════════════
    match /posts/{postId} {
      // Read: own posts always, active+public for others, active+private only for owner
      allow read: if isAuth()
                   && (
                     resource.data.userId == request.auth.uid
                     || (resource.data.status == 'active'
                         && resource.data.visibility == 'public')
                   );

      // Create: own post, content 1-500 chars, status must be 'active'
      allow create: if isAuth()
                     && request.resource.data.userId == request.auth.uid
                     && request.resource.data.content is string
                     && request.resource.data.content.size() >= 0
                     && request.resource.data.content.size() <= 500
                     && request.resource.data.status == 'active'
                     && request.resource.data.reportCount == 0
                     && request.resource.data.likeCount == 0;

      // Update by owner: imageUrl only (for post-create upload), OR editable fields (no time limit)
      allow update: if isAuth()
                     && resource.data.userId == request.auth.uid
                     && (
                       // Case 1: attach image after creation (imageUrl only)
                       changed().hasOnly(['imageUrl'])
                       ||
                       // Case 2: edit post fields (no time limit)
                       (changed().hasOnly(['content', 'mode', 'tags', 'region', 'visibility', 'dayNumber'])
                        && request.resource.data.content is string
                        && request.resource.data.content.size() >= 0
                        && request.resource.data.content.size() <= 500)
                     );

      // Update by anyone: likeCount changes (public active posts)
      allow update: if isAuth()
                     && resource.data.visibility == 'public'
                     && changed().hasOnly(['likeCount'])
                     && (request.resource.data.likeCount == resource.data.likeCount + 1
                         || request.resource.data.likeCount == resource.data.likeCount - 1);

      // Update by others: reportCount changes (public active posts only)
      allow update: if isAuth()
                     && resource.data.userId != request.auth.uid
                     && resource.data.visibility == 'public'
                     && (
                       // Case 1: increment reportCount only
                       (changed().hasOnly(['reportCount'])
                        && request.resource.data.reportCount == resource.data.reportCount + 1)
                       ||
                       // Case 2: increment reportCount + auto-hide when reaching threshold
                       (changed().hasOnly(['reportCount', 'status'])
                        && request.resource.data.reportCount == resource.data.reportCount + 1
                        && request.resource.data.reportCount >= 3
                        && request.resource.data.status == 'hidden')
                     );

      allow delete: if isAuth() && resource.data.userId == request.auth.uid;

      // Likes subcollection (only on public active posts)
      match /likes/{likeId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == likeId
                       && resource == null
                       && get(/databases/$(database)/documents/posts/$(postId)).data.visibility == 'public'
                       && get(/databases/$(database)/documents/posts/$(postId)).data.status == 'active';
        allow delete: if isAuth() && request.auth.uid == likeId;
      }

      // Post reports subcollection (prevent duplicate reports per user)
      match /reports/{reporterId} {
        allow read: if isAuth() && request.auth.uid == reporterId;
        allow create: if isAuth()
                       && request.auth.uid == reporterId
                       && resource == null;
      }
    }

    // ═══════════════════════════════════════════
    // Groups
    // ═══════════════════════════════════════════
    match /groups/{groupId} {
      // Read: only open groups (closed groups hidden from listing)
      // Members and creators can still read their closed groups
      allow read: if isAuth()
                   && (resource.data.isClosed == false
                       || request.auth.uid in resource.data.memberIds
                       || resource.data.creatorId == request.auth.uid);
      allow delete: if false;

      // Create: must be own group, correct initial state
      allow create: if isAuth()
                     && request.resource.data.creatorId == request.auth.uid
                     && request.resource.data.memberIds == [request.auth.uid]
                     && request.resource.data.memberCount == 1
                     && request.resource.data.isClosed == false
                     && request.resource.data.isOfficial == false
                     && request.resource.data.groupName is string
                     && request.resource.data.groupName.size() >= 1
                     && request.resource.data.groupName.size() <= 30;

      // Update by leader: settings (goal, iconUrl, isClosed, joinType)
      allow update: if isAuth()
                     && resource.data.creatorId == request.auth.uid
                     && changed().hasOnly(['goal', 'iconUrl', 'isClosed', 'joinType']);

      // Update by leader: kick a member (memberIds remove + memberCount decrement + kickedUserIds add)
      allow update: if isAuth()
                     && resource.data.creatorId == request.auth.uid
                     && changed().hasOnly(['memberIds', 'memberCount', 'kickedUserIds'])
                     && request.resource.data.memberCount == resource.data.memberCount - 1
                     && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1;

      // Update by leader: kick + close (when last member is kicked)
      allow update: if isAuth()
                     && resource.data.creatorId == request.auth.uid
                     && changed().hasOnly(['memberIds', 'memberCount', 'isClosed'])
                     && request.resource.data.memberCount == resource.data.memberCount - 1;

      // Join: add self to memberIds, increment memberCount
      // Mode groups (isOfficial && no iconUrl) have no cap; all others max 12
      // Kicked users cannot rejoin
      allow update: if isAuth()
                     && !(request.auth.uid in resource.data.memberIds)
                     && request.auth.uid in request.resource.data.memberIds
                     && changed().hasOnly(['memberIds', 'memberCount'])
                     && request.resource.data.memberCount == resource.data.memberCount + 1
                     && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
                     && ((resource.data.isOfficial == true && (!('iconUrl' in resource.data) || resource.data.iconUrl == ''))
                         || resource.data.memberCount < 12)
                     && (!('kickedUserIds' in resource.data) || !(request.auth.uid in resource.data.kickedUserIds));

      // Leave (non-leader): remove self from memberIds, decrement memberCount
      allow update: if isAuth()
                     && resource.data.creatorId != request.auth.uid
                     && request.auth.uid in resource.data.memberIds
                     && !(request.auth.uid in request.resource.data.memberIds)
                     && changed().hasOnly(['memberIds', 'memberCount'])
                     && request.resource.data.memberCount == resource.data.memberCount - 1
                     && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1;

      // Leave (non-leader) + auto-close when group becomes empty
      allow update: if isAuth()
                     && resource.data.creatorId != request.auth.uid
                     && request.auth.uid in resource.data.memberIds
                     && !(request.auth.uid in request.resource.data.memberIds)
                     && changed().hasOnly(['memberIds', 'memberCount', 'isClosed'])
                     && request.resource.data.memberCount == resource.data.memberCount - 1
                     && request.resource.data.isClosed == true;

      // Leader leave: close the group
      allow update: if isAuth()
                     && resource.data.creatorId == request.auth.uid
                     && request.auth.uid in resource.data.memberIds
                     && changed().hasOnly(['isClosed'])
                     && request.resource.data.isClosed == true;

      // Leader transfer: change creatorId + remove self from memberIds
      allow update: if isAuth()
                     && resource.data.creatorId == request.auth.uid
                     && request.auth.uid in resource.data.memberIds
                     && !(request.auth.uid in request.resource.data.memberIds)
                     && request.resource.data.creatorId in resource.data.memberIds
                     && request.resource.data.creatorId != request.auth.uid
                     && changed().hasOnly(['creatorId', 'memberIds', 'memberCount'])
                     && request.resource.data.memberCount == resource.data.memberCount - 1;

      // Member sends message: update lastMessageAt/Text/By
      allow update: if isAuth()
                     && request.auth.uid in resource.data.memberIds
                     && changed().hasOnly(['lastMessageAt', 'lastMessageText', 'lastMessageBy'])
                     && request.resource.data.lastMessageBy == request.auth.uid;

      // Last read tracking subcollection
      match /lastRead/{userId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuth()
                     && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
        allow create: if isAuth()
                      && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds
                      && (request.resource.data.senderId == request.auth.uid
                          || request.resource.data.senderId == 'system')
                      && request.resource.data.text is string
                      && request.resource.data.text.size() >= 1
                      && request.resource.data.text.size() <= 100
                      && !request.resource.data.text.matches('.*https?://.*')
                      && !request.resource.data.text.matches('.*www\\..*');
        // Reaction updates by any member
        allow update: if isAuth()
                      && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
        // Sender can edit text or unsend their own message (re-validate length)
        allow update: if isAuth()
                      && request.auth.uid == resource.data.senderId
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'edited', 'unsent'])
                      && request.resource.data.text is string
                      && (request.resource.data.unsent == true || (request.resource.data.text.size() >= 1 && request.resource.data.text.size() <= 100
                          && !request.resource.data.text.matches('.*https?://.*')
                          && !request.resource.data.text.matches('.*www\\..*')));
      }
    }

    // ═══════════════════════════════════════════
    // Reports (user reports)
    // ═══════════════════════════════════════════
    match /reports/{reportId} {
      allow read: if false;
      allow create: if isAuth()
                     && request.resource.data.reporterId == request.auth.uid
                     && request.resource.data.targetUserId is string
                     && request.resource.data.reason is string
                     && request.resource.data.reason.size() >= 1
                     && request.resource.data.resolved == false;
    }

    // ═══════════════════════════════════════════
    // Admin / Read-only configs
    // ═══════════════════════════════════════════
    match /admin_config/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /banners/{bannerId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /moderation_config/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Legal documents (Terms, Privacy, Legal Notice) — public read, editable via Firebase Console only
    match /legal_docs/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
